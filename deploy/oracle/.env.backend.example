# Oracle Cloud backend runtime example
# Copy to: /opt/openashare/backend/.env

LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Optional showcase gate.
# Set these to enable the lightweight demo unlock for AI analysis / portfolio / settings.
# If left empty, the showcase gate is disabled.
DEMO_ACCESS_CODE=your_demo_code
# If omitted, the code above is also used as the signing secret.
DEMO_ACCESS_SECRET=your_demo_secret

# Comma-separated origins that may call the backend from the browser.
# Add your Vercel deployment URL and any custom domain that serves the frontend.
CORS_ALLOWED_ORIGINS=https://openashare.com,https://www.openashare.com,https://your-project.vercel.app

DATA_COUNT=180
MONITOR_DB_PATH=/opt/openashare/backend/data/monitor.db

NEWS_TRACKING_ENABLED=true
FUND_FLOW_TRACKING_ENABLED=true
WEB_SEARCH_ENABLED=true

# Optional monitor settings
MONITOR_ENABLED=false
MONITOR_INTERVAL_SECONDS=300
ALERT_MIN_PRIORITY=3

# Service runtime
API_HOST=127.0.0.1
API_PORT=8000
# Use 1 on ~1GB RAM VMs (multiple workers duplicate memory).
API_WORKERS=1
