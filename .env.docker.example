# ==========================================
# Ashare AI Strategy Analyst Docker 配置示例
# ==========================================

# ====== LLM API 配置 ======
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ====== 监控与日志 ======
MONITOR_ENABLED=false
LOG_LEVEL=INFO
DEBUG=false

# ====== 数据路径 ======
# 容器内路径，docker-compose 已将宿主机 ./data 挂载到 /app/data
MONITOR_DB_PATH=/app/data/monitor.db

# ====== 可选推送配置 ======
SERVERCHAN_KEY=

